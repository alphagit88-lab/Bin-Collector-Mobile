{
  "expo": {
    "name": "Bin Rental",
    "slug": "binrental-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logo.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.binrental.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/logo.png",
        "backgroundColor": "#E6FBBF"
      },
      "package": "com.binrental.mobile",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCr6d4xZw6apWLl0VRVgDLytC8VDhLMdEI"
        }
      }
    },
    "web": {
      "favicon": "./src/assets/images/logo.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with suppliers.",
          "cameraPermission": "The app accesses your camera to let you take photos of bin placements."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ]
  }
}